    struct stat st;
    time_t now = time(NULL);
    struct tm *today = localtime(&now);
    
    if (stat(UNIQUE_VISITORS_FILE, &st) == 0) {
        struct tm *file_date = localtime(&st.st_mtime);
        if (today->tm_year != file_date->tm_year || 
            today->tm_mon != file_date->tm_mon || 
            today->tm_mday != file_date->tm_mday) {
            // 날짜가 바뀌었으면 파일 초기화
