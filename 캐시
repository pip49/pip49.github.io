
<script>
    // URL에서 쿼리 파라미터를 읽어오는 함수
    function getUrlParameter(name) {
        name = name.replace(/[\[]/, '\\[').replace(/[\]]/, '\\]');
        var regex = new RegExp('[\\?&]' + name + '=([^&#]*)');
        var results = regex.exec(location.search);
        return results === null ? '' : decodeURIComponent(results[1].replace(/\+/g, ' '));
    }

    // 3초마다 메시지를 새로고침하고 스크롤을 내리는 함수
    function refreshChat() {
        // GET 대신 POST 요청을 사용해 캐시를 완전히 무력화합니다.
        fetch('/cgi-bin/read.cgi', {
            method: 'POST',
            body: JSON.stringify({}) // 빈 데이터를 보내 POST 요청임을 명확히 함
        })
        .then(response => response.text())
        .then(htmlContent => {
            const chatbox = document.getElementById('chatbox');
            const isScrolledToBottom = chatbox.scrollHeight - chatbox.clientHeight <= chatbox.scrollTop + 1;

            chatbox.innerHTML = htmlContent;

            if (isScrolledToBottom) {
                chatbox.scrollTop = chatbox.scrollHeight;
            }
        })
        .catch(error => console.error('Error fetching chat messages:', error));
    }

    // 페이지가 완전히 로드되면 실행되는 메인 함수
    document.addEventListener('DOMContentLoaded', () => {
        // 1. URL에서 닉네임 파라미터를 읽어와 입력창에 채우기
        const urlUsername = getUrlParameter('username');
        if (urlUsername) {
            document.getElementById('username-input').value = urlUsername;
        }

        // 2. 초기 채팅 내용을 불러오고 스크롤을 맨 아래로 내림
        refreshChat();
        
        // 3. 3초마다 채팅창 자동 갱신 시작
        setInterval(refreshChat, 3000);
    });
</script>
